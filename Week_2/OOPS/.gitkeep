// File: music/Playable.java
package music;

public interface Playable {
    void play();
}
// File: music/string/Veena.java
package music.string;

import music.Playable;

public class Veena implements Playable {
    public void play() {
        System.out.println("Playing Veena");
    }
}
// File: music/wind/Saxophone.java
package music.wind;

import music.Playable;

public class Saxophone implements Playable {
    public void play() {
        System.out.println("Playing Saxophone");
    }
}
// File: live/Test.java
package live;

import music.Playable;
import music.string.Veena;
import music.wind.Saxophone;

public class Test {
    public static void main(String[] args) {

        // a. Create an instance of Veena and call play()
        Veena v = new Veena();
        v.play();

        // b. Create an instance of Saxophone and call play()
        Saxophone s = new Saxophone();
        s.play();

        // c. Place the above instances in a variable of type Playable
        Playable p;

        p = v;
        p.play();

        p = s;
        p.play();
    }
}
